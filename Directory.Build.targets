<Project>
  <Target Name="MoveLibrariesToLibs" AfterTargets="Build" Condition="'$(OutputType)' == 'Exe' Or '$(OutputType)' == 'WinExe'">
    <ItemGroup>
      <!-- Collect all DLLs/PDBs/XMLs but exclude the project's own output and first-party project DLLs -->
      <FilesToMove Include="$(OutDir)*.dll;$(OutDir)*.pdb;$(OutDir)*.xml"
                   Exclude="$(OutDir)$(TargetName).pdb;$(OutDir)$(TargetName).xml;$(OutDir)FrameWork.dll;$(OutDir)Common.dll" />
    </ItemGroup>
    <MakeDir Directories="$(OutDir)libs" />
    <Move SourceFiles="@(FilesToMove)" DestinationFolder="$(OutDir)libs" />
  </Target>
</Project>
