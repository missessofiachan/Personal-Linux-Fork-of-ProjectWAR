#!/bin/sh

REMOTE_NAME="$1"
REMOTE_URL="$2"

if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "agents/scripts/pre-push-guard.ps1" -RemoteName "$REMOTE_NAME" -RemoteUrl "$REMOTE_URL"
  exit $?
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "agents/scripts/pre-push-guard.ps1" -RemoteName "$REMOTE_NAME" -RemoteUrl "$REMOTE_URL"
  exit $?
fi

echo "Warning: PowerShell not found; skipping ProjectWAR pre-push guard." 1>&2
exit 0
